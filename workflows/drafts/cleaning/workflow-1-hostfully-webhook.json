    {
      "id": "38f8b16a-7d14-4451-8455-2be0c1de7914",
      "name": "Cancellation Idempotency Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1960,
        340
      ],
      "parameters": {
        "jsCode": "// If no reservation row exists the workflow stops at the lookup (alwaysOutputData: false)\n// So here we only need to handle the idempotency check\nconst lookup = $input.first().json;\nconst lead   = $('Unwrap Lead').first().json;\n\n// Already cancelled — idempotent, skip\nconst status = (lookup.cleaningStatus ?? '').toString().trim().toUpperCase();\nif (status === 'CANCELLED') return [];\n\nreturn [{ json: lead }];"
      }
    },
