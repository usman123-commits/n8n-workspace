      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        580
      ],
      "parameters": {
        "jsCode": "// If no reservation row exists the workflow stops at the lookup (alwaysOutputData: false)\n// So here we only need to check if the checkout date is genuinely later\nconst lookup    = $input.first().json;\nconst candidate = $('Prepare Extended Checkout Candidate').first().json;\n\n// Normalise both to ISO-like strings for safe string comparison\nconst sheetCO = (lookup.checkOut ?? '').toString().trim().replace(' ', 'T');\nconst newCO   = (candidate.newCheckOut ?? '').toString().trim().replace(' ', 'T');\n\n// Only proceed if new checkout is strictly later than stored\nif (!sheetCO || !newCO || newCO <= sheetCO) return [];\n\nreturn [{ json: candidate }];"
      }
