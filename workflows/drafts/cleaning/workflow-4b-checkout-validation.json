      "id": "f0a1b2c3-d4e5-6789-abcd-000000000005",
      "name": "Get Booking",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [-528, 864],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "q52dbWoN6OaKRDZO",
          "name": "Google Sheets account"
        }
      },
      "notes": "Looks up the CleaningJobs row by bookingUid.\nWhy: need fixedCleanerId, status, clockInTimeUTC, and propertyUid to validate against.",
      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "// Merge each submission (from Only PENDING) with its CleaningJobs row (Get Booking), by position.\nconst pendingItems = $('Only PENDING').all();\nconst jobItems = $input.all();\nreturn jobItems.map((jobItem, i) => {\n  const submission = pendingItems[i]?.json || {};\n  const job = jobItem.json || {};\n  return { json: { ...submission, ...job } };\n});"
      },
      "id": "f0a1b2c3-d4e5-6789-abcd-000000000006",
      "name": "Merge Submission and Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-304, 864],
      "notes": "Combines the checkout submission data with the CleaningJobs data by position index.\nWhy: validation needs both the form submission and the job details in one object.",
      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "// Run all pre-GPS validations: cleaner match, clock-in status, duration min/max.\nconst items = $input.all();\nreturn items.map(item => {\n  const j = item.json || {};\n\n  // 1. Cleaner match\n  const cleanerFromForm = (j.cleanerIdFromForm ?? '').toString().trim();\n  const assignedCleaner = (j.fixedCleanerId ?? '').toString().trim();\n  if (!cleanerFromForm || !assignedCleaner || cleanerFromForm !== assignedCleaner) {\n    return { json: { ...j, validationPass: 'FAIL', validationMsg: 'Cleaner not assigned to this booking' } };\n  }\n\n  // 2. Clock-in exists — job must be IN_PROGRESS\n  const jobStatus = (j.status ?? '').toString().trim();\n  if (jobStatus !== 'IN_PROGRESS') {\n    return { json: { ...j, validationPass: 'FAIL', validationMsg: 'No approved clock-in found' } };\n  }\n\n  // 3. Duration checks\n  const clockInTime = j.clockInTimeUTC ? new Date(j.clockInTimeUTC) : null;\n  const checkoutTime = j.submissionTimestamp ? new Date(j.submissionTimestamp) : null;\n\n  if (!clockInTime || isNaN(clockInTime.getTime()) || !checkoutTime || isNaN(checkoutTime.getTime())) {\n    return { json: { ...j, validationPass: 'FAIL', validationMsg: 'Invalid timestamp — cannot calculate duration' } };\n  }\n\n  const durationMs = checkoutTime.getTime() - clockInTime.getTime();\n  const durationMin = Math.round(durationMs / 60000);\n\n  if (durationMin < 30) {\n    return { json: { ...j, validationPass: 'FAIL', validationMsg: 'Checkout too soon (' + durationMin + ' min after clock-in)', durationMinutes: durationMin } };\n  }\n\n  if (durationMin > 360) {\n    const durationHrs = (durationMin / 60).toFixed(1);\n    return { json: { ...j, validationPass: 'FAIL', validationMsg: 'Checkout too late (' + durationHrs + ' hrs after clock-in)', durationMinutes: durationMin } };\n  }\n\n  return { json: { ...j, validationPass: 'PASS', validationMsg: 'Pre-GPS checks passed', durationMinutes: durationMin } };\n});"
      },
