      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "// Only continue if processingStatus = PENDING.\nconst items = $input.all();\nconst pending = items.filter(i => (i.json?.processingStatus ?? '').toString().trim() === 'PENDING');\nreturn pending.length ? pending : [];"
      },
