      "id": "f0a1b2c3-d4e5-6789-abcd-000000000011",
      "name": "Get Property Coordinates",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [368, 1056],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "q52dbWoN6OaKRDZO",
          "name": "Google Sheets account"
        }
      },
      "notes": "Looks up latitude/longitude from the Properties tab by propertyUid.\nWhy: compare the cleaner's GPS against the property location for radius check.",
      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "// Combine by position: validated submission (Pass Validated Items) with coords (Get Property Coordinates).\nconst submissionItems = $('Pass Validated Items').all();\nconst coordsItems = $input.all();\nconst len = Math.min(submissionItems.length, coordsItems.length);\nif (len === 0) return [];\nconst out = [];\nfor (let i = 0; i < len; i++) {\n  const sub = submissionItems[i]?.json || {};\n  const coord = coordsItems[i]?.json || {};\n  out.push({ json: { ...sub, ...coord } });\n}\nreturn out;"
      },
      "id": "f0a1b2c3-d4e5-6789-abcd-000000000012",
      "name": "Merge Coords with Submission",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [816, 1056],
      "notes": "Re-merges the validated submission data with property coordinates by position.\nWhy: distance calculation needs both GPS points in one object.",
      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "// Haversine distance in meters between cleaner GPS and property GPS.\nconst items = $input.all();\nconst R = 6371000;\nconst toRad = deg => deg * (Math.PI / 180);\nreturn items.map(item => {\n  const j = item.json || {};\n  const userLat = parseFloat(j.gpsLat);\n  const userLng = parseFloat(j.gpsLng);\n  const propertyLat = parseFloat(j.latitude);\n  const propertyLng = parseFloat(j.longitude);\n  let distance = NaN;\n  if (Number.isFinite(userLat) && Number.isFinite(userLng) && Number.isFinite(propertyLat) && Number.isFinite(propertyLng)) {\n    const dLat = toRad(propertyLat - userLat);\n    const dLng = toRad(propertyLng - userLng);\n    const a = Math.sin(dLat/2)*Math.sin(dLat/2) + Math.cos(toRad(userLat))*Math.cos(toRad(propertyLat))*Math.sin(dLng/2)*Math.sin(dLng/2);\n    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));\n    distance = R * c;\n  }\n  return { json: { ...j, distance: Number.isFinite(distance) ? Math.round(distance) : 999999 } };\n});"
      },
      "id": "f0a1b2c3-d4e5-6789-abcd-000000000013",
      "name": "Distance Calculation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 1056],
      "notes": "Haversine formula: calculates meters between cleaner GPS and property GPS.\nAdds distance (rounded meters) to each item. Defaults to 999999 if coords invalid.",
      "notesInFlow": false
    },
