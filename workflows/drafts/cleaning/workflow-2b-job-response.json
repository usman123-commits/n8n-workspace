                "jsCode": "const job = $('Validate & Route').first().json;\nconst existingDeclined = (job.declinedBy || '').toString().trim();\nconst cleanerId = (job.cleanerId || '').toString().trim();\nconst declinedList = existingDeclined ? existingDeclined.split(',').map(s => s.trim()).filter(Boolean) : [];\nif (!declinedList.includes(cleanerId)) {\n  declinedList.push(cleanerId);\n}\nreturn [{ json: {\n  bookingUid: job.bookingUid,\n  declinedBy: declinedList.join(','),\n  propertyName: job.propertyName || job.propertyUid || ''\n} }];"
            },
