        },
        {
            "parameters": {
                "jsCode": "const DURATION_HOURS = 3;\nconst startTime = ($json.scheduledCleaningTimeUTC || '').toString().trim();\nif (!startTime) throw new Error('Missing scheduledCleaningTimeUTC');\nconst startDate = new Date(startTime);\nif (isNaN(startDate.getTime())) throw new Error('Invalid scheduledCleaningTimeUTC');\nconst endDate = new Date(startDate.getTime() + DURATION_HOURS * 3600 * 1000);\nreturn [{ json: { ...$input.first().json, startTime, endTime: endDate.toISOString(), durationHours: DURATION_HOURS } }];"
            },
