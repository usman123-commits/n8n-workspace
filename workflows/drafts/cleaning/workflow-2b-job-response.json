            "id": "10b00004-aaaa-4bbb-cccc-dd0000000004",
            "name": "Read Job",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.4,
            "position": [480, 0],
            "credentials": {
                "googleSheetsOAuth2Api": {
