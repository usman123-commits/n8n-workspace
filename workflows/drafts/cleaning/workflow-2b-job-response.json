        {
            "parameters": {
                "jsCode": "const job = $('Validate & Route').first().json;\nconst cleanerItems = $('Read Cleaner Row').all();\nconst propertyItems = $('Read Property Row').all();\nconst reservationItems = $input.all();\n\nconst cleaner = cleanerItems.length > 0 ? cleanerItems[0].json : {};\nconst property = propertyItems.length > 0 ? propertyItems[0].json : {};\nconst reservation = reservationItems.length > 0 && reservationItems[0].json?.bookingUid ? reservationItems[0].json : {};\n\nconst propertyName = (property.propertyName || reservation.propertyName || job.propertyUid || '').toString().trim();\nconst address = (property.address || reservation.address || 'Address TBD').toString().trim();\nconst fixedCleanerId = (property.fixedCleanerId || '').toString().trim();\nconst isFixed = fixedCleanerId !== '' && fixedCleanerId === job.cleanerId;\n\nreturn [{ json: {\n  ...job,\n  cleanerEmail: cleaner.email || '',\n  cleanerCalendarId: cleaner.calendarId || '',\n  cleanerName: cleaner.name || '',\n  cleanerContact: cleaner.phone || '',\n  propertyName,\n  address,\n  adultCount: reservation.adultCount || '0',\n  childrenCount: reservation.childrenCount || '0',\n  guestName: reservation.guestName || '',\n  _isFixedAssignment: isFixed,\n  assignedAt: new Date().toISOString()\n} }];"
            },
