        {
            "parameters": {
                "jsCode": "const params = $('Parse Request').first().json;\nconst { bookingUid, cleanerId, response } = params;\n\nif (!bookingUid || !cleanerId || !response) {\n  return [{ json: { _action: 'error', _errorMsg: 'Missing required parameters (bookingUid, cleanerId, response).' } }];\n}\nif (response !== 'accept' && response !== 'decline') {\n  return [{ json: { _action: 'error', _errorMsg: 'Response must be accept or decline.' } }];\n}\n\nconst jobItems = $input.all();\nif (jobItems.length === 0 || !jobItems[0].json?.bookingUid) {\n  return [{ json: { _action: 'error', _errorMsg: 'Job not found for bookingUid: ' + bookingUid } }];\n}\n\nconst job = jobItems[0].json;\nconst status = (job.status || '').toString().trim();\nconst offeredTo = (job.offeredTo || '').toString().trim();\n\nif (status === 'ASSIGNED') {\n  return [{ json: { _action: 'error', _errorMsg: 'This job has already been accepted.' } }];\n}\nif (status !== 'OFFERED') {\n  return [{ json: { _action: 'error', _errorMsg: 'This job is no longer available (status: ' + status + ').' } }];\n}\nif (offeredTo !== cleanerId) {\n  return [{ json: { _action: 'error', _errorMsg: 'This offer was not sent to you.' } }];\n}\n\nreturn [{ json: { ...job, cleanerId, _action: response } }];"
            },
