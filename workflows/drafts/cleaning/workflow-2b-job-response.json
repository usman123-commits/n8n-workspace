        },
        {
            "parameters": {
                "jsCode": "const BASE_URL = 'https://n8n-forms.vercel.app';\nconst bookingUid = $json.bookingUid;\nconst cleanerId = $json.cleanerId;\nconst params = 'bookingId=' + encodeURIComponent(bookingUid || '') + '&cleanerId=' + encodeURIComponent(cleanerId || '');\nconst clockInLink = BASE_URL + '/clockin?' + params;\nconst checkoutLink = BASE_URL + '/checkout?' + params;\nreturn [{ json: { ...$input.first().json, clockInLink, checkoutLink } }];"
            },
