    {
      "id": "a1b2c3d4-000b-4000-a000-000000000011",
      "name": "Extract Thread UID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 520],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst opportunities = raw.opportunities || raw.data || [];\n\nif (opportunities.length === 0) {\n  // No open Hostfully opportunities for this contact -- skip silently\n  return [];\n}\n\n// Pick the most recently created open opportunity (last booking)\nconst opp = opportunities[0];\nconst customFields = opp.customFields || [];\n\nconst threadFieldId = $('Config').first().json.OPP_CF_HOSTFULLY_THREAD_UID;\nif (!threadFieldId || threadFieldId.startsWith('PLACEHOLDER')) {\n  return [];\n}\n\nlet threadUid = '';\nfor (const cf of customFields) {\n  if ((cf.id || cf.fieldId) === threadFieldId) {\n    threadUid = cf.value || cf.field_value || cf.fieldValue || '';\n    break;\n  }\n}\n\nif (!threadUid) {\n  return [];\n}\n\nconst srcMsg = $('Filter Outbound Messages').item.json;\n\nreturn [{\n  json: {\n    threadUid,\n    ghlContactId: srcMsg.ghlContactId,\n    ghlOpportunityId: opp.id || '',\n    ghlMessageId: srcMsg.ghlMessageId,\n    messageKey: srcMsg.messageKey,\n    messageBody: srcMsg.messageBody\n  }\n}];"
      }
