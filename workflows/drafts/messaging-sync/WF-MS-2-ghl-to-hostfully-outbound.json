    {
      "id": "a1b2c3d4-0007-4000-a000-000000000007",
      "name": "Filter Outbound Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 400],
      "parameters": {
        "jsCode": "// GHL messages endpoint returns: { messages: { lastMessageId, nextPage, messages: [...] } }\n// The array is nested at response.messages.messages\nconst cutoffISO = $('Build Poll Window').first().json.startAfterDateISO;\nconst cutoff = new Date(cutoffISO).getTime();\nconst results = [];\n\nfor (const item of $input.all()) {\n  const outer = item.json.messages || {};\n  // Handle both shapes just in case: direct array or nested under .messages\n  const messages = Array.isArray(outer) ? outer : (outer.messages || []);\n\n  for (const msg of messages) {\n    const rawDate = msg.dateAdded || msg.createdAt || '';\n    const msgTime = rawDate ? new Date(rawDate).getTime() : 0;\n    const direction = (msg.direction || '').toLowerCase();\n    if (direction === 'outbound' && msgTime >= cutoff) {\n      results.push({\n        json: {\n          ghlMessageId: msg.id || '',\n          ghlContactId: msg.contactId || '',\n          conversationId: msg.conversationId || '',\n          messageBody: msg.body || msg.message || '',\n          dateAdded: rawDate,\n          messageKey: 'ghl:' + (msg.id || '')\n        }\n      });\n    }\n  }\n}\n\nreturn results;"
      }
