    {
      "id": "6715889d-db12-4cb6-95b5-2378747e02e5",
      "name": "Unwrap Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2180, 500],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst msg = raw.message || raw;\nif (!msg.uid && !msg.message_uid && !msg.id) {\n  throw new Error('Hostfully message response unexpected shape: ' + JSON.stringify(raw).slice(0, 300));\n}\nreturn [{ json: {\n  uid: msg.uid || msg.message_uid || msg.id || '',\n  threadUid: msg.threadUid || msg.thread_uid || $('Build Dedup Key').first().json.threadUid,\n  leadUid: msg.leadUid || msg.lead_uid || '',\n  propertyUid: msg.propertyUid || msg.property_uid || '',\n  type: msg.type || '',\n  body: msg.body || msg.content || msg.message || '',\n  createdAt: msg.createdAt || msg.created_at || ''\n}}];"
