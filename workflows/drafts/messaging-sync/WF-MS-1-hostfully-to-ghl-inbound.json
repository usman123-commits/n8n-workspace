      "typeVersion": 2,
      "position": [3280, 620],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst lead = raw.lead || raw;\nconst msg = $('Unwrap Message').first().json;\nconst keys = $('Build Dedup Key').first().json;\n\nreturn [{\n  json: {\n    leadUid: msg.leadUid || '',\n    threadUid: keys.threadUid,\n    propertyUid: msg.propertyUid || lead.propertyUid || '',\n    firstName: lead.firstName || lead.first_name || '',\n    lastName: lead.lastName || lead.last_name || '',\n    email: lead.email || '',\n    phone: lead.phone || '',\n    channel: lead.source || lead.channel || 'Direct',\n    checkIn: lead.checkInDate || lead.checkIn || '',\n    checkOut: lead.checkOutDate || lead.checkOut || ''\n  }\n}];"
