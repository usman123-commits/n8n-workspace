    {
      "parameters": {
        "jsCode": "// Format history for Gemini API (contents array)\nconst allItems = $input.all();\nconst vars = $('Prepare Variables').item.json;\n\nlet contents = [];\n\nfor (const item of allItems) {\n  const row = item.json;\n  if (!row.message_text || !row.direction) continue;\n  // Gemini uses 'model' instead of 'assistant'\n  contents.push({\n    role: row.direction === 'outgoing' ? 'model' : 'user',\n    parts: [{ text: String(row.message_text) }]\n  });\n}\n\n// Keep last 9 to leave room for current message\ncontents = contents.slice(-9);\n\n// Append current incoming message\ncontents.push({\n  role: 'user',\n  parts: [{ text: vars.incoming_message }]\n});\n\nreturn [{ json: { contents } }];"
      },
      "id": "code-001",
      "name": "Format History for Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        304
      ]
    },
