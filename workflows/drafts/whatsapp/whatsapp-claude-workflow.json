    {
      "parameters": {
        "jsCode": "// Format group history for Claude with sender names\nconst allItems = $input.all();\nconst vars = $('Prepare Variables').item.json;\n\nlet contents = [];\n\nfor (const item of allItems) {\n  const row = item.json;\n  if (!row.message_text || !row.direction) continue;\n  const senderLabel = row.direction === 'outgoing' ? 'Zara' : (row.contact_name || 'User');\n  contents.push({\n    role: row.direction === 'outgoing' ? 'assistant' : 'user',\n    content: row.direction === 'outgoing' ? row.message_text : '[' + senderLabel + ']: ' + row.message_text\n  });\n}\n\ncontents = contents.slice(-15);\n\ncontents.push({\n  role: 'user',\n  content: '[' + vars.contact_name + ']: ' + vars.incoming_message\n});\n\nreturn [{ json: { contents } }];"
      },
