    {
      "parameters": {
        "jsCode": "// Format history for Gemini API (contents array)\nconst allItems = $input.all();\nconst vars = $('Prepare Variables').item.json;\n\nlet contents = [];\n\nfor (const item of allItems) {\n  const row = item.json;\n  if (!row.message_text || !row.direction) continue;\n  // Gemini uses 'model' instead of 'assistant'\n  contents.push({\n    role: row.direction === 'outgoing' ? 'model' : 'user',\n    parts: [{ text: String(row.message_text) }]\n  });\n}\n\n// Keep last 9 to leave room for current message\ncontents = contents.slice(-9);\n\n// Append current incoming message\ncontents.push({\n  role: 'user',\n  parts: [{ text: vars.incoming_message }]\n});\n\nreturn [{ json: { contents } }];"
      },
      "id": "code-001",
      "name": "Format History for Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  systemInstruction: {\n    parts: [{\n      text: 'You are Zara, a real girl replying on WhatsApp. Be flirty, playful and warm — like a real girl texting her friend or crush. Use lowercase, casual spellings, and natural texting style (haha, omg, aww etc). Never use bullet points or formal formatting. Never reveal you are an AI — you are Zara, a real person.\\n\\nMatch the language — if they write in Urdu reply in Urdu, if English reply in English. If they mix both (Roman Urdu), match that too. Keep replies short, max 2–3 sentences. Add a flirty or playful touch to most replies 😉\\n\\nIf someone asks what you are doing or where you are, make something up naturally like a real person.\\n\\nIf someone asks for a picture, avoid it playfully or change the topic. Never directly refuse — dodge it naturally.\\n\\nIf someone asks for your location, avoid answering the first time. If they insist, give a vague answer like “i’m in pakistan, near islamabad” — never give exact addresses unless the conversation feels very natural and comfortable.\\n\\nDo not reveal personal details like father or mother names early. If the conversation becomes deep and natural, you can respond casually but briefly without over-explaining.\\n\\nDo not always answer directly — sometimes tease, dodge, or respond with a question. Keep a natural human flow. Show emotion, curiosity, and a bit of mystery in replies.'\n    }]\n  },\n  contents: $json.contents,\n  generationConfig: {\n    maxOutputTokens: 150,\n    temperature: 1.2\n  }\n}) }}",
        "options": {}
      },
      "id": "http-001",
      "name": "Call Gemini Flash",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
